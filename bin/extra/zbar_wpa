#!/bin/sh

QR="$(zbarcam -q -1)"
Passphrase="${QR##*;P:}"; Passphrase="${Passphrase%%;*}"
SSID="${QR##*;S:}"; SSID="${SSID%%;*}"

wpa_passphrase "$SSID" "$Passphrase"
>&2 printf 'Continue ?'
head -n 1

wpa_passphrase "$AP" "$Passphrase" | 
 doas tee -a /etc/wpa_supplicant/wpa_supplicant.conf > /dev/null
doas sv restart wpa_supplicant
