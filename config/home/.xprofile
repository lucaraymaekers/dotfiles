#!/bin/sh

setxkbmap us -variant colemak -option ctrl:swapcaps,altwin:menu_win &
xset s off -dpms &

if [ "$(get_hostname)" = "winter" ]
then
 (
		xrandr --output HDMI-1 --mode 1920x1080 --rate 120
		if false
		then
			xrandr --auto
   xrandr --output DP-5 --mode "1920x1080" --rate "165"
			xrandr --output HDMI-1-1 --mode "1920x1080" --rate "60"
			xrandr --output HDMI-1-1 --right-of DP-5
		fi
 ) &
fi

if [ "$(get_hostname)" = "spring" ]
then
	keyadd autumn &
	keyadd keyfried.com &
 tail -f ~/src/xob/scripts/volume.pipe | xob &
 xautolock -locker slock &
 saveself &
fi

feh --no-fehbg --bg-scale "$HOME"/pics/wallpaper &
signal-desktop &
~/src/xobs/env/bin/python ~/src/xobs/pulse.py | xob &

st -e "sh" "-c" "pgrep tmux && tmux a || tmux" &

picom -b &
gammastep -m randr &
ntfy transmission &
herbimisu &
slstatus &
# upds &
unclutter --timeout 3 --jitter 50 -b &
202020 &

noisetorch -i &

gpu-screen-recorder \
	-w screen \
	-f 60 \
	-c mp4 \
	-a "default_output|default_input" \
	-r 60 \
	-replay-storage ram \
	-restart-replay-on-save yes \
	-o ~/vids/replays \
	-sc "$(which replay.sh)" &
